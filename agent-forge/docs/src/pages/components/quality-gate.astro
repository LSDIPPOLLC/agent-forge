---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="QualityGate">
  <h1>QualityGate</h1>

  <p>Decides whether an agent passes or fails based on its ScoreReport, configurable thresholds, and coverage checks.</p>

  <h2>Interface</h2>
  <pre><code>import QualityGate from "agent-forge/quality_gate";

const gate = new QualityGate(0.85);  // default threshold

const result = gate.check(scoreReport);
// result.passed: boolean
// result.warnings: string array
// result.blocked: boolean (coverage gaps)
// result.compositeScore: number</code></pre>

  <h2>QualityGateResult</h2>
  <pre><code>interface QualityGateResult &lcub;
  passed: boolean;       // composite greater-or-equal threshold AND not blocked
  warnings: string[];    // non-blocking alerts
  blocked: boolean;       // true if coverage gaps exist
  compositeScore: number;
&rcub;</code></pre>

  <h2>Pass Conditions</h2>
  <p>An agent passes if and only if:</p>
  <ol>
    <li>composite score greater-or-equal threshold</li>
    <li>coverage gaps length equals zero</li>
  </ol>
  <p>If coverage gaps exist, blocked is true regardless of score.</p>

  <h2>Warning Conditions</h2>
  <p>Warnings are attached (but don't block) for:</p>
  <ul>
    <li>testPassRate less than 0.5 — "Low test pass rate"</li>
    <li>judgeScore less than 0.5 — "Low LLM judge score"</li>
    <li>generalizationWarning present — shadow eval failure</li>
    <li>coverageGaps.length greater than 0 — listed as warning AND blocks</li>
  </ul>

  <h2>Default Threshold</h2>
  <pre><code>composite = 0.6 * testPassRate + 0.4 * judgeScore

// With default 0.85 threshold:
// - 100% test pass + 100% judge = 1.0 = PASS
// - 100% test pass + 50% judge = 0.8 = FAIL
// - 50% test pass + 100% judge = 0.7 = FAIL
// - 85% test pass + 85% judge = 0.85 = PASS</code></pre>

  <h2>Customization</h2>
  <pre><code>// Different threshold per task
const strictGate = new QualityGate(0.95);
const lenientGate = new QualityGate(0.70);

// Change threshold dynamically
gate.setThreshold(0.90);</code></pre>
</Layout>
